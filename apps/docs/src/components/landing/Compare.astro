---
const before = `import { trace as otelTrace } from '@opentelemetry/api';
import { NodeSDK } from '@opentelemetry/sdk-node';
import { OTLPTraceExporter }
  from '@opentelemetry/exporter-trace-otlp-http';
import { Resource } from '@opentelemetry/resources';
import { SemanticResourceAttributes }
  from '@opentelemetry/semantic-conventions';

const sdk = new NodeSDK({
  resource: new Resource({
    [SemanticResourceAttributes.SERVICE_NAME]: 'my-api',
  }),
  traceExporter: new OTLPTraceExporter({
    url: 'http://localhost:4318/v1/traces',
  }),
});
sdk.start();

const tracer = otelTrace.getTracer('my-api');

export async function checkout(req, res) {
  const span = tracer.startSpan('checkout');
  try {
    const result = await processCheckout(req.body);
    span.setStatus({ code: 1 });
    return res.json(result);
  } catch (err) {
    span.recordException(err);
    span.setStatus({ code: 2 });
    throw err;
  } finally {
    span.end();
  }
}`;

const after = `import { init, trace } from 'autotel';

init({ service: 'my-api', endpoint: 'http://localhost:4318' });

export const checkout = trace((ctx) =>
  async (req, res) => {
    const result = await processCheckout(req.body);
    return res.json(result);
  },
);`;
---

<section class="compare" aria-labelledby="compare-title">
  <div class="compare__inner">
    <header class="compare__head">
      <p class="compare__eyebrow">Before / after</p>
      <h2 id="compare-title" class="compare__title">
        Same telemetry. A fraction of the surface area.
      </h2>
      <p class="compare__sub">
        Autotel keeps OpenTelemetry compatibility intact. You just stop writing
        the plumbing.
      </p>
    </header>

    <div class="compare__grid sl-markdown-no-margin">
      <figure class="panel panel--before">
        <figcaption class="panel__head">
          <span class="panel__tag">raw OpenTelemetry</span>
          <span class="panel__count">~36 lines</span>
        </figcaption>
        <pre class="panel__code"><code>{before}</code></pre>
      </figure>

      <figure class="panel panel--after">
        <figcaption class="panel__head">
          <span class="panel__tag panel__tag--accent">
            <span class="panel__tag-dot" aria-hidden="true"></span>
            autotel
          </span>
          <span class="panel__count">8 lines</span>
        </figcaption>
        <pre class="panel__code"><code>{after}</code></pre>
      </figure>
    </div>
  </div>
</section>

<style>
  .compare {
    border-top: 1px solid var(--color-charcoal-grey);
    padding-block: clamp(3rem, 6vw, 5rem);
  }

  :root[data-theme='light'] .compare {
    border-top-color: var(--sl-color-gray-5);
  }

  .compare__inner {
    max-width: 72rem;
    margin-inline: auto;
    padding-inline: clamp(1rem, 4vw, 2rem);
  }

  .compare__head {
    max-width: 48rem;
    margin-bottom: 2.25rem;
  }

  .compare__eyebrow {
    margin: 0 0 0.5rem;
    font-family: var(--sl-font);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-storm-cloud);
    font-weight: 510;
  }

  .compare__title {
    margin: 0 0 0.625rem;
    font-family: var(--sl-font);
    font-size: clamp(1.5rem, 3vw, 2.125rem);
    line-height: 1.18;
    letter-spacing: -0.02em;
    color: var(--color-porcelain);
    font-weight: 590;
    border: 0;
  }

  :root[data-theme='light'] .compare__title {
    color: var(--color-pitch-black);
  }

  .compare__sub {
    margin: 0;
    color: var(--color-light-steel);
    font-size: 0.9375rem;
    line-height: 1.55;
    max-width: 38rem;
    letter-spacing: -0.012em;
  }

  :root[data-theme='light'] .compare__sub {
    color: var(--sl-color-gray-2);
  }

  .compare__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 900px) {
    .compare__grid {
      grid-template-columns: 1fr 1fr;
      gap: 1.25rem;
      align-items: start;
    }
  }

  /* Before panel — Graphite card, full opacity (no fake "fading out the loser"
     trick). Hierarchy comes from the autotel panel having its own beat. */
  .panel {
    margin: 0;
    border: 1px solid var(--color-charcoal-grey);
    border-radius: 6px;
    overflow: hidden;
    background: var(--color-graphite);
    box-shadow: var(--shadow-card);
  }

  :root[data-theme='light'] .panel {
    border-color: var(--sl-color-gray-5);
    background: var(--sl-color-bg-inline-code);
  }

  /* "after" panel — elevated surface + single blue hairline. */
  .panel--after {
    background: var(--color-deep-slate);
    position: relative;
  }

  :root[data-theme='light'] .panel--after {
    background: #ffffff;
  }

  .panel--after::before {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 1px;
    background: var(--color-aether-blue);
    opacity: 0.95;
    z-index: 1;
  }

  .panel__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.625rem 0.95rem;
    border-bottom: 1px solid var(--color-charcoal-grey);
    font-family: var(--sl-font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-fog-grey);
  }

  :root[data-theme='light'] .panel__head {
    border-bottom-color: var(--sl-color-gray-5);
  }

  .panel__tag {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .panel__tag--accent {
    color: var(--color-porcelain);
    font-weight: 510;
    letter-spacing: 0.06em;
  }

  :root[data-theme='light'] .panel__tag--accent {
    color: var(--color-pitch-black);
  }

  .panel__tag-dot {
    width: 0.375rem;
    height: 0.375rem;
    border-radius: 999px;
    background: var(--color-aether-blue);
    box-shadow: 0 0 8px color-mix(in oklch, var(--color-aether-blue) 50%, transparent);
  }

  .panel__count {
    color: var(--color-fog-grey);
    font-variant-numeric: tabular-nums;
  }

  .panel__code {
    margin: 0;
    padding: 1rem 1.125rem 1.25rem;
    background: transparent;
    font-family: var(--sl-font-mono);
    font-size: 0.78rem;
    line-height: 1.6;
    color: var(--color-light-steel);
    overflow-x: auto;
    border: 0;
    border-radius: 0;
    letter-spacing: -0.005em;
  }

  :root[data-theme='light'] .panel__code {
    color: var(--sl-color-gray-2);
  }

  .panel__code code {
    background: transparent;
    padding: 0;
    color: inherit;
  }

  .panel--after .panel__code {
    color: var(--color-porcelain);
  }

  :root[data-theme='light'] .panel--after .panel__code {
    color: var(--color-pitch-black);
  }
</style>
