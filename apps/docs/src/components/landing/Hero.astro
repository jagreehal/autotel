---
import HeroTraceIsland from './HeroTraceIsland';

const installCmd = 'npm install autotel';
---

<section class="hero" aria-labelledby="hero-title">
  <div class="hero__inner">
    <p class="eyebrow">
      <span class="dot" aria-hidden="true"></span>
      <span>v1.x</span>
      <span class="eyebrow__sep" aria-hidden="true">·</span>
      <span>MIT</span>
      <span class="eyebrow__sep" aria-hidden="true">·</span>
      <span>OpenTelemetry-native</span>
    </p>

    <h1 id="hero-title" class="wordmark">
      autotel<span class="cursor" aria-hidden="true">_</span>
    </h1>

    <p class="tagline">
      Zero-boilerplate OpenTelemetry for TypeScript. Trace functions, track product
      events, and ship structured errors with one import.
    </p>

    <div class="actions">
      <a class="btn btn--primary" href="/autotel/quick-start/">
        <span>Get started</span>
        <span class="arrow" aria-hidden="true">→</span>
      </a>
      <a class="btn btn--ghost" href="https://github.com/jagreehal/autotel">
        <span>GitHub</span>
        <span class="arrow" aria-hidden="true">↗</span>
      </a>
    </div>

    <div class="install" role="group" aria-label="Install command">
      <span class="prompt" aria-hidden="true">$</span>
      <code>{installCmd}</code>
    </div>

    <HeroTraceIsland client:visible />
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-block: clamp(3rem, 7vw, 6rem) clamp(2rem, 4vw, 4rem);
    isolation: isolate;
  }

  /* Subtle blue glow: top-right wash + faint bottom-left lift behind trace. */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      radial-gradient(
        ellipse 55% 60% at 85% -10%,
        color-mix(in oklch, var(--color-aether-blue) 22%, transparent),
        transparent 60%
      ),
      radial-gradient(
        ellipse 45% 35% at -5% 110%,
        color-mix(in oklch, var(--color-aether-blue) 10%, transparent),
        transparent 60%
      );
    pointer-events: none;
  }

  :root[data-theme='light'] .hero::before {
    background:
      radial-gradient(
        ellipse 55% 60% at 85% -10%,
        color-mix(in oklch, var(--color-aether-blue) 10%, transparent),
        transparent 60%
      );
  }

  .hero__inner {
    max-width: 72rem;
    margin-inline: auto;
    padding-inline: clamp(1rem, 4vw, 2rem);
  }

  /* Eyebrow — Inter, not mono. Tracked uppercase is a typesetting choice;
     monospace would be reflexive "developer vibes." */
  .eyebrow {
    font-family: var(--sl-font);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-storm-cloud);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0 0 1.75rem;
    font-weight: 510;
  }

  .eyebrow__sep {
    color: var(--color-fog-grey);
  }

  .dot {
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 999px;
    background: var(--color-aether-blue);
    box-shadow:
      0 0 0 4px color-mix(in oklch, var(--color-aether-blue) 18%, transparent),
      0 0 12px color-mix(in oklch, var(--color-aether-blue) 45%, transparent);
    animation: pulse 2.4s ease-in-out infinite;
    margin-right: 0.25rem;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.78); }
  }

  /* Wordmark — mono as mark; cursor uses the same accent as CTAs. */
  .wordmark {
    font-family: var(--sl-font-mono);
    font-size: clamp(3.5rem, 10.5vw, 7.5rem);
    line-height: 0.92;
    letter-spacing: -0.04em;
    font-weight: 400;
    margin: 0 0 1.5rem;
    color: var(--color-porcelain);
    border: 0;
  }

  :root[data-theme='light'] .wordmark {
    color: var(--color-pitch-black);
  }

  .cursor {
    display: inline-block;
    color: var(--color-aether-blue);
    margin-left: 0.05em;
    text-shadow: 0 0 18px color-mix(in oklch, var(--color-aether-blue) 55%, transparent);
    animation: blink 1.05s steps(1) infinite;
  }

  @keyframes blink {
    50% { opacity: 0; }
  }

  .tagline {
    font-family: var(--sl-font);
    font-size: clamp(1rem, 1.3vw, 1.1875rem);
    line-height: 1.5;
    color: var(--color-light-steel);
    max-width: 44ch;
    margin: 0 0 2.25rem;
    letter-spacing: -0.013em;
  }

  :root[data-theme='light'] .tagline {
    color: var(--sl-color-gray-2);
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
    margin-bottom: 1.5rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1rem;
    font-family: var(--sl-font);
    font-size: 0.875rem;
    font-weight: 590;
    letter-spacing: -0.011em;
    text-decoration: none;
    border-radius: 6px;
    transition:
      background var(--sl-transition),
      border-color var(--sl-transition),
      color var(--sl-transition);
  }

  .btn .arrow {
    transition: transform 200ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .btn:hover .arrow {
    transform: translateX(2px);
  }

  .btn--primary {
    background: var(--color-aether-blue);
    color: var(--color-porcelain);
    border: 1px solid var(--color-aether-blue);
    box-shadow:
      0 1px 0 0 rgba(255, 255, 255, 0.18) inset,
      0 6px 24px -8px color-mix(in oklch, var(--color-aether-blue) 42%, transparent);
  }

  .btn--primary:hover {
    background: var(--color-aether-blue-soft);
    border-color: var(--color-aether-blue-soft);
    color: var(--color-porcelain);
  }

  :root[data-theme='light'] .btn--primary {
    background: var(--sl-color-accent);
    color: var(--color-porcelain);
    border-color: var(--sl-color-accent);
    box-shadow:
      0 1px 0 0 rgba(255, 255, 255, 0.2) inset,
      0 6px 24px -8px color-mix(in oklch, var(--sl-color-accent) 35%, transparent);
  }

  :root[data-theme='light'] .btn--primary:hover {
    background: var(--sl-color-accent-high);
    border-color: var(--sl-color-accent-high);
    color: var(--color-porcelain);
  }

  .btn--ghost {
    background: transparent;
    color: var(--color-porcelain);
    border: 1px solid var(--color-charcoal-grey);
  }

  :root[data-theme='light'] .btn--ghost {
    color: var(--color-pitch-black);
    border-color: var(--sl-color-gray-5);
  }

  .btn--ghost:hover {
    border-color: var(--color-gunmetal);
    background: var(--color-graphite);
  }

  :root[data-theme='light'] .btn--ghost:hover {
    background: var(--sl-color-gray-6);
    border-color: var(--sl-color-gray-4);
  }

  .install {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.5rem 0.875rem;
    border: 1px solid var(--color-charcoal-grey);
    border-radius: 6px;
    background: var(--color-graphite);
    font-family: var(--sl-font-mono);
    font-size: 0.8125rem;
    margin-bottom: 3.5rem;
    box-shadow: var(--shadow-card);
  }

  :root[data-theme='light'] .install {
    border-color: var(--sl-color-gray-5);
    background: var(--sl-color-bg-inline-code);
  }

  .install .prompt {
    color: var(--color-aether-blue);
    user-select: none;
    font-weight: 590;
  }

  .install code {
    color: var(--color-porcelain);
    background: transparent;
    padding: 0;
    border: 0;
    border-radius: 0;
  }

  :root[data-theme='light'] .install code {
    color: var(--color-pitch-black);
  }

  @media (prefers-reduced-motion: reduce) {
    .cursor,
    .dot {
      animation: none !important;
    }
  }
</style>
