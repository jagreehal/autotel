---
import HeroTraceIsland from './HeroTraceIsland';

const installCmd = 'npm install autotel';
---

<section class="hero" aria-labelledby="hero-title">
  <div class="hero__grid">
    <div class="hero__copy">
      <p class="eyebrow">
        <span>v1.x</span>
        <span class="eyebrow__sep" aria-hidden="true">/</span>
        <span>Apache-2.0</span>
        <span class="eyebrow__sep" aria-hidden="true">/</span>
        <span>OpenTelemetry-native</span>
      </p>

      <h1 id="hero-title" class="wordmark">
        autotel<span class="cursor" aria-hidden="true">_</span>
      </h1>

      <p class="tagline">
        Zero-boilerplate OpenTelemetry for TypeScript. Wrap a function and get
        spans, product events, and structured errors without the SDK wiring.
      </p>

      <div class="install" role="group" aria-label="Install command">
        <span class="prompt" aria-hidden="true">$</span>
        <code>{installCmd}</code>
      </div>

      <div class="actions">
        <a class="btn btn--primary" href="/autotel/quick-start/">
          <span>Get started</span>
          <span class="arrow" aria-hidden="true">→</span>
        </a>
        <a class="btn btn--ghost" href="https://github.com/jagreehal/autotel">
          <span>GitHub</span>
          <span class="arrow" aria-hidden="true">↗</span>
        </a>
      </div>
    </div>

    <div class="hero__trace">
      <HeroTraceIsland client:visible />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-block: clamp(2.5rem, 6vw, 5.5rem) clamp(2rem, 5vw, 4.5rem);
    isolation: isolate;
  }

  .hero__grid {
    max-width: 72rem;
    margin-inline: auto;
    padding-inline: clamp(1rem, 4vw, 2rem);
    display: grid;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }

  @media (min-width: 900px) {
    .hero__grid {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.02fr);
    }
  }

  .hero__copy {
    min-width: 0;
  }

  /* Eyebrow — mono, tracked, quiet grey. No accent dot: blue lives only in the trace. */
  .eyebrow {
    font-family: var(--sl-font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-storm-cloud);
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    margin: 0 0 1.75rem;
    font-weight: 510;
  }

  .eyebrow__sep {
    color: var(--color-fog-grey);
  }

  .wordmark {
    font-family: var(--sl-font-mono);
    font-size: clamp(3.25rem, 8.5vw, 6rem);
    line-height: 0.94;
    letter-spacing: -0.045em;
    font-weight: 400;
    margin: 0 0 1.5rem;
    color: var(--color-porcelain);
    border: 0;
  }

  /* White blinking cursor — the terminal motif, kept monochrome. */
  .cursor {
    display: inline-block;
    color: var(--color-porcelain);
    margin-left: 0.03em;
    animation: blink 1.05s steps(1) infinite;
  }

  @keyframes blink {
    50% {
      opacity: 0;
    }
  }

  .tagline {
    font-family: var(--sl-font-mono);
    font-size: clamp(0.9375rem, 1.1vw, 1.0625rem);
    line-height: 1.6;
    color: var(--color-light-steel);
    max-width: 46ch;
    margin: 0 0 2rem;
    letter-spacing: -0.005em;
  }

  .install {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.55rem 0.95rem;
    border: 1px solid var(--color-charcoal-grey);
    border-radius: 6px;
    background: var(--color-graphite);
    font-family: var(--sl-font-mono);
    font-size: 0.8125rem;
    margin-bottom: 1.75rem;
  }

  .install .prompt {
    color: var(--color-storm-cloud);
    user-select: none;
    font-weight: 590;
  }

  .install code {
    color: var(--color-porcelain);
    background: transparent;
    padding: 0;
    border: 0;
    border-radius: 0;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.05rem;
    font-family: var(--sl-font-mono);
    font-size: 0.8125rem;
    font-weight: 510;
    letter-spacing: -0.005em;
    text-decoration: none;
    border-radius: 6px;
    transition:
      background var(--sl-transition),
      border-color var(--sl-transition),
      color var(--sl-transition);
  }

  .btn .arrow {
    transition: transform 200ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .btn:hover .arrow {
    transform: translateX(2px);
  }

  /* Primary is white-on-black — the strongest monochrome move, no blue needed. */
  .btn--primary {
    background: var(--color-porcelain);
    color: var(--color-pitch-black);
    border: 1px solid var(--color-porcelain);
  }

  .btn--primary:hover {
    background: var(--color-alabaster);
    border-color: var(--color-alabaster);
  }

  .btn--ghost {
    background: transparent;
    color: var(--color-porcelain);
    border: 1px solid var(--color-muted-ash);
  }

  .btn--ghost:hover {
    border-color: var(--color-gunmetal);
    background: var(--color-graphite);
  }

  .hero__trace {
    min-width: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .cursor {
      animation: none !important;
    }
  }
</style>
