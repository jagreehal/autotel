---
const installCmd = 'npm install autotel';
const spans = [
  { name: 'POST /checkout', start: 0, width: 100, ms: '124ms', depth: 0, kind: 'root' },
  { name: 'auth.verify', start: 4, width: 14, ms: '18ms', depth: 1, kind: 'child' },
  { name: 'db.query', start: 20, width: 38, ms: '47ms', depth: 1, kind: 'child' },
  { name: 'stripe.charge', start: 60, width: 38, ms: '52ms', depth: 1, kind: 'error' },
];
---

<section class="hero" aria-labelledby="hero-title">
  <div class="hero__inner">
    <p class="eyebrow">
      <span class="dot" aria-hidden="true"></span>
      <span>v1.x</span>
      <span class="eyebrow__sep" aria-hidden="true">·</span>
      <span>MIT</span>
      <span class="eyebrow__sep" aria-hidden="true">·</span>
      <span>OpenTelemetry-native</span>
    </p>

    <h1 id="hero-title" class="wordmark">
      autotel<span class="cursor" aria-hidden="true">_</span>
    </h1>

    <p class="tagline">
      Zero-boilerplate OpenTelemetry for TypeScript. Trace functions, track product
      events, and ship structured errors with one import.
    </p>

    <div class="actions">
      <a class="btn btn--primary" href="/autotel/quick-start/">
        <span>Get started</span>
        <span class="arrow" aria-hidden="true">→</span>
      </a>
      <a class="btn btn--ghost" href="https://github.com/jagreehal/autotel">
        <span>GitHub</span>
        <span class="arrow" aria-hidden="true">↗</span>
      </a>
    </div>

    <div class="install" role="group" aria-label="Install command">
      <span class="prompt" aria-hidden="true">$</span>
      <code>{installCmd}</code>
    </div>

    <figure class="trace" aria-label="Example trace waterfall">
      <figcaption class="trace__head">
        <span class="trace__label">trace</span>
        <span class="trace__id">b5e1·c0ff·ee42</span>
        <span class="trace__total">total 124ms</span>
      </figcaption>

      <ol class="trace__list">
        {spans.map((s) => (
          <li
            class:list={[
              'trace__row',
              s.depth === 1 && 'trace__row--child',
              s.kind === 'error' && 'trace__row--error',
              s.kind === 'root' && 'trace__row--root',
            ]}
          >
            <span class="trace__name">
              {s.depth === 1 ? <span class="trace__branch" aria-hidden="true">└─</span> : null}
              {s.name}
            </span>
            <span class="trace__bar-track">
              <span
                class="trace__bar"
                style={`--bar-start:${s.start}%;--bar-width:${s.width}%`}
              ></span>
            </span>
            <span class="trace__ms">{s.ms}</span>
          </li>
        ))}
      </ol>
    </figure>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-block: clamp(3rem, 7vw, 6rem) clamp(2rem, 4vw, 4rem);
    isolation: isolate;
  }

  /* Subtle Aether Blue glow top-right, Neon Lime barely-there bottom-left.
     The lime ambient sits behind the trace so the figure picks up a hint of
     reflected light without painting the canvas. */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      radial-gradient(
        ellipse 55% 60% at 85% -10%,
        color-mix(in oklch, var(--color-aether-blue) 22%, transparent),
        transparent 60%
      ),
      radial-gradient(
        ellipse 45% 35% at -5% 110%,
        color-mix(in oklch, var(--color-neon-lime) 8%, transparent),
        transparent 60%
      );
    pointer-events: none;
  }

  :root[data-theme='light'] .hero::before {
    background:
      radial-gradient(
        ellipse 55% 60% at 85% -10%,
        color-mix(in oklch, var(--color-aether-blue) 10%, transparent),
        transparent 60%
      );
  }

  .hero__inner {
    max-width: 72rem;
    margin-inline: auto;
    padding-inline: clamp(1rem, 4vw, 2rem);
  }

  /* Eyebrow — Inter, not mono. Tracked uppercase is a typesetting choice;
     monospace would be reflexive "developer vibes." */
  .eyebrow {
    font-family: var(--sl-font);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-storm-cloud);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0 0 1.75rem;
    font-weight: 510;
  }

  .eyebrow__sep {
    color: var(--color-fog-grey);
  }

  .dot {
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 999px;
    background: var(--color-neon-lime);
    box-shadow:
      0 0 0 4px color-mix(in oklch, var(--color-neon-lime) 14%, transparent),
      0 0 12px color-mix(in oklch, var(--color-neon-lime) 40%, transparent);
    animation: pulse 2.4s ease-in-out infinite;
    margin-right: 0.25rem;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.78); }
  }

  /* Wordmark — Berkeley Mono fallback. This is the brand mark, NOT a label —
     monospace here is meaningful: it IS the logo. The cursor is the single
     concentrated lime accent that anchors the page. */
  .wordmark {
    font-family: var(--sl-font-mono);
    font-size: clamp(3.5rem, 10.5vw, 7.5rem);
    line-height: 0.92;
    letter-spacing: -0.04em;
    font-weight: 400;
    margin: 0 0 1.5rem;
    color: var(--color-porcelain);
    border: 0;
  }

  :root[data-theme='light'] .wordmark {
    color: var(--color-pitch-black);
  }

  .cursor {
    display: inline-block;
    color: var(--color-neon-lime);
    margin-left: 0.05em;
    text-shadow: 0 0 18px color-mix(in oklch, var(--color-neon-lime) 50%, transparent);
    animation: blink 1.05s steps(1) infinite;
  }

  @keyframes blink {
    50% { opacity: 0; }
  }

  .tagline {
    font-family: var(--sl-font);
    font-size: clamp(1rem, 1.3vw, 1.1875rem);
    line-height: 1.5;
    color: var(--color-light-steel);
    max-width: 44ch;
    margin: 0 0 2.25rem;
    letter-spacing: -0.013em;
  }

  :root[data-theme='light'] .tagline {
    color: var(--sl-color-gray-2);
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
    margin-bottom: 1.5rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1rem;
    font-family: var(--sl-font);
    font-size: 0.875rem;
    font-weight: 590;
    letter-spacing: -0.011em;
    text-decoration: none;
    border-radius: 6px;
    transition:
      background var(--sl-transition),
      border-color var(--sl-transition),
      color var(--sl-transition);
  }

  .btn .arrow {
    transition: transform 200ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .btn:hover .arrow {
    transform: translateX(2px);
  }

  /* THE primary action — Linear's lime-on-black. Used exactly once on this
     page (the install command also uses lime, but as a $-prompt accent, not a
     filled action). */
  .btn--primary {
    background: var(--color-neon-lime);
    color: var(--color-pitch-black);
    border: 1px solid var(--color-neon-lime);
    box-shadow:
      0 1px 0 0 rgba(255, 255, 255, 0.12) inset,
      0 6px 24px -8px color-mix(in oklch, var(--color-neon-lime) 35%, transparent);
  }

  .btn--primary:hover {
    background: color-mix(in oklch, var(--color-neon-lime) 92%, white 8%);
    border-color: color-mix(in oklch, var(--color-neon-lime) 92%, white 8%);
  }

  .btn--ghost {
    background: transparent;
    color: var(--color-porcelain);
    border: 1px solid var(--color-charcoal-grey);
  }

  :root[data-theme='light'] .btn--ghost {
    color: var(--color-pitch-black);
    border-color: var(--sl-color-gray-5);
  }

  .btn--ghost:hover {
    border-color: var(--color-gunmetal);
    background: var(--color-graphite);
  }

  :root[data-theme='light'] .btn--ghost:hover {
    background: var(--sl-color-gray-6);
    border-color: var(--sl-color-gray-4);
  }

  .install {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.5rem 0.875rem;
    border: 1px solid var(--color-charcoal-grey);
    border-radius: 6px;
    background: var(--color-graphite);
    font-family: var(--sl-font-mono);
    font-size: 0.8125rem;
    margin-bottom: 3.5rem;
    box-shadow: var(--shadow-card);
  }

  :root[data-theme='light'] .install {
    border-color: var(--sl-color-gray-5);
    background: var(--sl-color-bg-inline-code);
  }

  /* The $-prompt is the second precise lime moment — paired with the cursor.
     Two specks of lime in the hero is the brief: "lit by precise accents." */
  .install .prompt {
    color: var(--color-neon-lime);
    user-select: none;
    font-weight: 590;
  }

  .install code {
    color: var(--color-porcelain);
    background: transparent;
    padding: 0;
    border: 0;
    border-radius: 0;
  }

  :root[data-theme='light'] .install code {
    color: var(--color-pitch-black);
  }

  /* ---- Trace waterfall — a small command-center readout ---- */
  .trace {
    margin: 0;
    border: 1px solid var(--color-charcoal-grey);
    border-radius: 8px;
    background: var(--color-graphite);
    box-shadow: var(--shadow-card);
    overflow: hidden;
  }

  :root[data-theme='light'] .trace {
    border-color: var(--sl-color-gray-5);
    background: var(--sl-color-bg-inline-code);
  }

  .trace__head {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 0.625rem 1rem;
    border-bottom: 1px solid var(--color-charcoal-grey);
    font-family: var(--sl-font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-fog-grey);
  }

  :root[data-theme='light'] .trace__head {
    border-bottom-color: var(--sl-color-gray-5);
  }

  .trace__label {
    color: var(--color-storm-cloud);
    font-weight: 510;
  }

  .trace__id {
    color: var(--color-light-steel);
    text-transform: none;
    letter-spacing: 0;
    font-size: 0.75rem;
  }

  .trace__total {
    margin-left: auto;
  }

  .trace__list {
    list-style: none;
    margin: 0;
    padding: 0.375rem 0;
  }

  .trace__row {
    display: grid;
    grid-template-columns: minmax(8rem, 14rem) 1fr 4rem;
    align-items: center;
    gap: 1rem;
    padding: 0.4rem 1rem;
    font-family: var(--sl-font-mono);
    font-size: 0.8125rem;
    color: var(--color-light-steel);
  }

  :root[data-theme='light'] .trace__row {
    color: var(--sl-color-gray-2);
  }

  .trace__row--root .trace__name {
    color: var(--color-porcelain);
    font-weight: 510;
  }

  :root[data-theme='light'] .trace__row--root .trace__name {
    color: var(--color-pitch-black);
  }

  .trace__row--child {
    color: var(--color-storm-cloud);
  }

  :root[data-theme='light'] .trace__row--child {
    color: var(--sl-color-gray-3);
  }

  .trace__branch {
    color: var(--color-fog-grey);
    margin-right: 0.4rem;
  }

  :root[data-theme='light'] .trace__branch {
    color: var(--sl-color-gray-4);
  }

  .trace__name {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .trace__bar-track {
    position: relative;
    height: 0.75rem;
    background: var(--color-pitch-black);
    border-radius: 2px;
    overflow: hidden;
  }

  :root[data-theme='light'] .trace__bar-track {
    background: var(--sl-color-gray-6);
  }

  .trace__bar {
    position: absolute;
    top: 0;
    bottom: 0;
    left: var(--bar-start);
    width: var(--bar-width);
    background: var(--color-storm-cloud);
    border-radius: 2px;
    transform-origin: left;
    animation: span-grow 720ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
  }

  .trace__row--root .trace__bar {
    background: var(--color-light-steel);
  }

  /* Error remains red — semantic. Lime is for action, never error. */
  .trace__row--error .trace__bar {
    background: var(--color-warning-red);
    box-shadow: 0 0 0 1px color-mix(in oklch, var(--color-warning-red) 28%, transparent);
    animation:
      span-grow 720ms cubic-bezier(0.2, 0.8, 0.2, 1) both,
      span-pulse 2.4s ease-in-out 1.2s infinite;
  }

  .trace__row--error .trace__ms {
    color: var(--color-warning-red);
  }

  .trace__row:nth-child(1) .trace__bar { animation-delay: 0ms; }
  .trace__row:nth-child(2) .trace__bar { animation-delay: 120ms; }
  .trace__row:nth-child(3) .trace__bar { animation-delay: 240ms; }
  .trace__row:nth-child(4) .trace__bar { animation-delay: 360ms; }

  @keyframes span-grow {
    from { transform: scaleX(0); opacity: 0.4; }
    to { transform: scaleX(1); opacity: 1; }
  }

  @keyframes span-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.7; }
  }

  .trace__ms {
    text-align: right;
    color: var(--color-fog-grey);
    font-size: 0.75rem;
    font-variant-numeric: tabular-nums;
  }

  @media (prefers-reduced-motion: reduce) {
    .cursor,
    .dot,
    .trace__bar {
      animation: none !important;
    }
    .trace__bar {
      transform: scaleX(1);
      opacity: 1;
    }
  }

  @media (max-width: 640px) {
    .trace__row {
      grid-template-columns: minmax(6rem, 9rem) 1fr 3rem;
      gap: 0.5rem;
      font-size: 0.75rem;
    }
    .trace__head {
      gap: 0.75rem;
    }
  }
</style>
