---
const frameworks = [
  { name: 'Express', href: '/autotel/frameworks/express/' },
  { name: 'Fastify', href: '/autotel/frameworks/fastify/' },
  { name: 'NestJS', href: '/autotel/frameworks/nestjs/' },
  { name: 'Hono', href: '/autotel/frameworks/hono/' },
  { name: 'TanStack Start', href: '/autotel/frameworks/tanstack/' },
  { name: 'Cloudflare Workers', href: '/autotel/frameworks/cloudflare/' },
  { name: 'Edge runtimes', href: '/autotel/frameworks/edge/' },
  { name: 'Adapters', href: '/autotel/frameworks/adapters/' },
];

const integrations = [
  { name: 'Prisma', href: '/autotel/integrations/prisma/' },
  { name: 'Drizzle', href: '/autotel/integrations/drizzle/' },
  { name: 'Mongoose', href: '/autotel/integrations/mongoose/' },
  { name: 'AWS', href: '/autotel/integrations/aws/' },
  { name: 'MCP', href: '/autotel/integrations/mcp/' },
  { name: 'Sentry', href: '/autotel/integrations/sentry/' },
  { name: 'Datadog', href: '/autotel/integrations/datadog/' },
  { name: 'PostHog', href: '/autotel/integrations/subscribers/' },
];
---

<section class="frameworks" aria-labelledby="frameworks-title">
  <div class="frameworks__inner">
    <header class="frameworks__head">
      <p class="frameworks__eyebrow">Surface coverage</p>
      <h2 id="frameworks-title" class="frameworks__title">
        Wire it once. Run it anywhere Node, Bun, or the edge runs.
      </h2>
    </header>

    <div class="block">
      <p class="block__label">
        <span class="block__label-num" aria-hidden="true">01</span>
        Frameworks
      </p>
      <ul class="grid sl-markdown-no-margin">
        {frameworks.map((f) => (
          <li>
            <a class="chip" href={f.href}>
              <span class="chip__name">{f.name}</span>
              <span class="chip__arrow" aria-hidden="true">→</span>
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div class="block">
      <p class="block__label">
        <span class="block__label-num" aria-hidden="true">02</span>
        Integrations
      </p>
      <ul class="grid sl-markdown-no-margin">
        {integrations.map((f) => (
          <li>
            <a class="chip" href={f.href}>
              <span class="chip__name">{f.name}</span>
              <span class="chip__arrow" aria-hidden="true">→</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .frameworks {
    border-top: 1px solid var(--color-charcoal-grey);
    padding-block: clamp(3rem, 6vw, 5rem);
  }

  :root[data-theme='light'] .frameworks {
    border-top-color: var(--sl-color-gray-5);
  }

  .frameworks__inner {
    max-width: 72rem;
    margin-inline: auto;
    padding-inline: clamp(1rem, 4vw, 2rem);
  }

  .frameworks__head {
    max-width: 48rem;
    margin-bottom: 2.25rem;
  }

  .frameworks__eyebrow {
    margin: 0 0 0.5rem;
    font-family: var(--sl-font);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-storm-cloud);
    font-weight: 510;
  }

  .frameworks__title {
    margin: 0;
    font-family: var(--sl-font);
    font-size: clamp(1.5rem, 3vw, 2.125rem);
    line-height: 1.18;
    letter-spacing: -0.02em;
    color: var(--color-porcelain);
    font-weight: 590;
    border: 0;
  }

  :root[data-theme='light'] .frameworks__title {
    color: var(--color-pitch-black);
  }

  .block + .block {
    margin-top: 2rem;
  }

  .block__label {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    font-family: var(--sl-font);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-storm-cloud);
    margin: 0 0 0.875rem;
    font-weight: 510;
  }

  .block__label-num {
    font-family: var(--sl-font-mono);
    color: var(--color-fog-grey);
    letter-spacing: 0.04em;
    font-variant-numeric: tabular-nums;
  }

  .grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 12rem), 1fr));
    gap: 1px;
    background: var(--color-charcoal-grey);
    border: 1px solid var(--color-charcoal-grey);
    border-radius: 6px;
    overflow: hidden;
  }

  :root[data-theme='light'] .grid {
    background: var(--sl-color-gray-5);
    border-color: var(--sl-color-gray-5);
  }

  .chip {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem;
    padding: 0.875rem 1rem;
    background: var(--color-graphite);
    color: var(--color-porcelain);
    font-family: var(--sl-font);
    font-size: 0.875rem;
    font-weight: 510;
    letter-spacing: -0.011em;
    text-decoration: none;
    transition:
      background var(--sl-transition),
      color var(--sl-transition);
  }

  :root[data-theme='light'] .chip {
    background: #ffffff;
    color: var(--color-pitch-black);
  }

  .chip__arrow {
    color: var(--color-fog-grey);
    transition:
      transform 200ms cubic-bezier(0.2, 0.8, 0.2, 1),
      color var(--sl-transition);
  }

  .chip:hover {
    background: var(--color-deep-slate);
    color: var(--color-porcelain);
  }

  :root[data-theme='light'] .chip:hover {
    background: var(--sl-color-gray-6);
  }

  .chip:hover .chip__arrow {
    color: var(--color-aether-blue);
    transform: translateX(2px);
  }

  :root[data-theme='light'] .chip:hover .chip__arrow {
    color: var(--sl-color-accent);
  }
</style>
