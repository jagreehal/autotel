---
const year = new Date().getFullYear();
---

<section class="cta" aria-labelledby="cta-title">
  <div class="cta__inner">
    <div class="cta__copy">
      <p class="cta__eyebrow">Ready to instrument?</p>
      <h2 id="cta-title" class="cta__title">
        One install. One <code>init()</code>. Every span, every backend.
      </h2>
    </div>
    <div class="cta__actions">
      <a class="cta__btn cta__btn--primary" href="/autotel/quick-start/">
        Quick start <span aria-hidden="true">→</span>
      </a>
      <a class="cta__btn cta__btn--ghost" href="/autotel/introduction/">
        Read the intro
      </a>
    </div>
  </div>

  <footer class="foot">
    <div class="foot__inner">
      <span class="foot__name">autotel</span>
      <span class="foot__sep" aria-hidden="true">·</span>
      <span>MIT licensed</span>
      <span class="foot__sep" aria-hidden="true">·</span>
      <a href="https://github.com/jagreehal/autotel">GitHub</a>
      <span class="foot__sep" aria-hidden="true">·</span>
      <a href="https://github.com/jagreehal/autotel/blob/main/CHANGELOG.md">
        Changelog
      </a>
      <span class="foot__year">© {year}</span>
    </div>
  </footer>
</section>

<style>
  .cta {
    border-top: 1px solid var(--sl-color-gray-6);
    padding-block: clamp(3rem, 6vw, 5rem) 0;
  }

  .cta__inner {
    max-width: 72rem;
    margin-inline: auto;
    padding-inline: clamp(1rem, 4vw, 2rem);
    display: grid;
    gap: 2rem;
    align-items: end;
  }

  @media (min-width: 760px) {
    .cta__inner {
      grid-template-columns: 1fr auto;
    }
  }

  .cta__eyebrow {
    margin: 0 0 0.5rem;
    font-family: var(--sl-font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--sl-color-accent);
  }

  .cta__title {
    margin: 0;
    font-family: var(--sl-font);
    font-size: clamp(1.5rem, 3vw, 2rem);
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--sl-color-white);
    max-width: 32ch;
    border: 0;
  }

  .cta__title code {
    font-family: var(--sl-font-mono);
    font-size: 0.85em;
    background: var(--sl-color-bg-inline-code);
    border-radius: 4px;
    padding: 0.05em 0.35em;
    color: var(--sl-color-accent);
  }

  .cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .cta__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.1rem;
    font-family: var(--sl-font-mono);
    font-size: 0.85rem;
    text-decoration: none;
    border-radius: 6px;
    transition:
      background 150ms ease,
      border-color 150ms ease,
      color 150ms ease;
  }

  .cta__btn--primary {
    background: var(--sl-color-accent);
    color: #ffffff;
    border: 1px solid var(--sl-color-accent);
  }

  .cta__btn--primary:hover {
    background: color-mix(in oklch, var(--sl-color-accent) 88%, white);
  }

  .cta__btn--ghost {
    background: transparent;
    color: var(--sl-color-text);
    border: 1px solid var(--sl-color-gray-5);
  }

  .cta__btn--ghost:hover {
    border-color: var(--sl-color-accent);
    color: var(--sl-color-accent);
  }

  .foot {
    margin-top: clamp(3rem, 6vw, 5rem);
    border-top: 1px solid var(--sl-color-gray-6);
    padding-block: 1.25rem;
    background: color-mix(in oklch, var(--sl-color-bg) 92%, var(--sl-color-gray-6));
  }

  .foot__inner {
    max-width: 72rem;
    margin-inline: auto;
    padding-inline: clamp(1rem, 4vw, 2rem);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--sl-font-mono);
    font-size: 0.78rem;
    color: var(--sl-color-gray-3);
  }

  .foot__name {
    color: var(--sl-color-text);
    font-weight: 500;
  }

  .foot__sep {
    color: var(--sl-color-gray-5);
  }

  .foot a {
    color: var(--sl-color-gray-2);
    text-decoration: none;
  }

  .foot a:hover {
    color: var(--sl-color-accent);
  }

  .foot__year {
    margin-left: auto;
    color: var(--sl-color-gray-4);
  }
</style>
