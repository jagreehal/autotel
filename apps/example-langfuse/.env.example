# Langfuse credentials — get them from Project Settings in your Langfuse project.
# Free cloud tier: https://cloud.langfuse.com  (or self-host).
# Without these, the example still runs and prints spans locally; it just won't
# forward them to Langfuse.
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASEURL=https://cloud.langfuse.com

# Fan out to autotel-devtools too (run `npx autotel-devtools` first)
# DEVTOOLS=1
# DEVTOOLS_ENDPOINT=http://127.0.0.1:4318

# Ollama model overrides (optional). Default granite4 is reliable with tools.
# OLLAMA_MODEL=granite4
# OLLAMA_EMBED_MODEL=nomic-embed-text
