{
  "name": "@jagreehal/example-langfuse",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Instrument once with autotel-genai's canonical gen_ai.* spans and fan them out to Langfuse and autotel-devtools using autotel's native OTLP destinations — no extra OpenTelemetry libs.",
  "scripts": {
    "start": "tsx src/index.ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@langfuse/tracing": "^5.6.0",
    "@opentelemetry/api": "^1.9.1",
    "ai": "7.0.0-beta.179",
    "ai-sdk-ollama": "4.0.0-beta.0",
    "autotel": "workspace:*",
    "autotel-genai": "workspace:*",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
