{
  "name": "@jagreehal/example-contract-testing",
  "version": "0.2.11",
  "description": "Runtime evidence for Pact contracts using autotel-pact. Demonstrates the 'contracted but never observed' audit on a real MessageConsumerPact flow.",
  "private": true,
  "type": "module",
  "author": "Jag Reehal",
  "license": "MIT",
  "scripts": {
    "start": "tsx src/index.ts",
    "test": "tsx src/index.ts",
    "pact:audit": "autotel-pact audit --pacts pacts --ledger .autotel-pact",
    "pact:audit:gate": "autotel-pact audit --pacts pacts --ledger .autotel-pact --gate",
    "pact:audit:broker": "autotel-pact audit --pacts pacts --ledger .autotel-pact --gate=broker"
  },
  "dependencies": {
    "@pact-foundation/pact": "^16.5.0",
    "autotel": "workspace:*",
    "autotel-pact": "workspace:*",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "observability",
    "contract-testing",
    "pact",
    "pact-message",
    "tracing",
    "opentelemetry",
    "runtime-evidence",
    "autotel"
  ]
}
