# OTLP Endpoint for telemetry export
# Default: http://localhost:4318 (local OTEL Collector)
# Examples:
#   Jaeger:         http://localhost:4318
#   Datadog:        https://api.datadoghq.com/v1/input/<API_KEY>
#   Grafana Cloud:  https://otlp-gateway-<REGION>.grafana.net/otlp
OTLP_ENDPOINT=http://localhost:4318

# Enable debug logging to console instead of exporting to OTLP
# Useful for local testing when OTLP backend is unavailable
DEBUG=false
