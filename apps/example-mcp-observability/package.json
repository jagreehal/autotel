{
  "name": "@jagreehal/example-mcp-observability",
  "version": "1.0.41",
  "private": true,
  "type": "module",
  "description": "Example demonstrating AI-assisted observability with autotel and OpenTelemetry MCP server",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "setup": "pnpm docker:up && echo '\\n✅ Jaeger started at http://localhost:16686\\n'"
  },
  "dependencies": {
    "autotel": "workspace:*",
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "express": "^5.2.1",
    "dotenv": "^17.4.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
