{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autotel.dev/schemas/recommendation-generated/1.0.0.json",
  "title": "RecommendationGenerated",
  "type": "object",
  "required": [
    "orderId",
    "recommendations",
    "model",
    "usage",
    "personalization_seed"
  ],
  "properties": {
    "orderId": { "type": "string", "format": "uuid" },
    "recommendations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["sku", "score"],
        "properties": {
          "sku": { "type": "string" },
          "score": { "type": "number", "minimum": 0, "maximum": 1 },
          "reason": { "type": "string" }
        }
      }
    },
    "model": { "type": "string" },
    "usage": {
      "type": "object",
      "required": ["promptTokens", "completionTokens"],
      "properties": {
        "promptTokens": { "type": "integer" },
        "completionTokens": { "type": "integer" }
      }
    },
    "personalization_seed": {
      "type": "string",
      "description": "Seed used to derive deterministic personalization for the order. Declared at the track() call site via defineEvent."
    }
  }
}
