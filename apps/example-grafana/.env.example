# Grafana Cloud OTLP ingestion (required for sending traces, metrics, logs)
# Get these from: Grafana Cloud Portal → your stack → Connections → OpenTelemetry → Configure
OTEL_EXPORTER_OTLP_ENDPOINT="https://otlp-gateway-prod-gb-south-1.grafana.net/otlp"
OTEL_EXPORTER_OTLP_HEADERS="Authorization=Basic%20YOUR_BASE64_INSTANCE_ID_AND_TOKEN"

# Optional: service name (default: example-grafana)
# OTEL_SERVICE_NAME=example-grafana

# Optional: enable debug (span output to console)
# DEBUG=false

# Optional: Grafana Cloud token (glc_...) — for API / reference, not used for OTLP
# GRAFANA_CLOUD_TOKEN=glc_your_token_here
