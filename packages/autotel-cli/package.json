{
  "name": "autotel-cli",
  "version": "0.8.9",
  "description": "CLI for autotel - setup wizard, diagnostics, and incremental features",
  "type": "module",
  "bin": {
    "autotel": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --config vitest.unit.config.ts",
    "test:watch": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.3",
    "autotel-mcp": "workspace:*",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "glob": "^13.0.6",
    "ora": "^9.4.0",
    "semver": "^7.8.0",
    "ts-morph": "^28.0.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/node": "^25.7.0",
    "@types/semver": "^7.7.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-unicorn": "^64.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "opentelemetry",
    "tracing",
    "observability",
    "cli",
    "autotel"
  ],
  "author": "Jag Reehal<jag@jagreehal.com> (https://jagreehal.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jagreehal/autotel"
  },
  "bugs": {
    "url": "https://github.com/jagreehal/autotel/issues"
  },
  "homepage": "https://github.com/jagreehal/autotel#readme"
}
