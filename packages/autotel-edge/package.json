{
  "name": "autotel-edge",
  "version": "3.17.2",
  "description": "Vendor-agnostic OpenTelemetry for edge runtimes - foundation for Cloudflare, Vercel, Netlify, Deno",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./sampling": {
      "types": "./dist/sampling.d.ts",
      "import": "./dist/sampling.js"
    },
    "./events": {
      "types": "./dist/events.d.ts",
      "import": "./dist/events.js"
    },
    "./logger": {
      "types": "./dist/logger.d.ts",
      "import": "./dist/logger.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js"
    },
    "./parse-error": {
      "types": "./dist/parse-error.d.ts",
      "import": "./dist/parse-error.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "skills"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "keywords": [
    "opentelemetry",
    "otel",
    "edge",
    "serverless",
    "observability",
    "tracing",
    "vendor-agnostic",
    "cloudflare",
    "vercel",
    "netlify",
    "deno"
  ],
  "author": "Jag Reehal <jag@jagreehal.com> (https://jagreehal.com)",
  "license": "Apache-2.0",
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/core": "^2.9.0",
    "@opentelemetry/otlp-exporter-base": "^0.220.0",
    "@opentelemetry/otlp-transformer": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-trace-base": "^2.9.0",
    "@opentelemetry/semantic-conventions": "^1.43.0"
  },
  "devDependencies": {
    "@opentelemetry/context-async-hooks": "^2.9.0",
    "@types/node": "^26.1.1",
    "rimraf": "^6.1.3",
    "tsdown": "^0.22.12",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "vitest-mock-extended": "^5.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jagreehal/autotel",
    "directory": "packages/autotel-edge"
  },
  "bugs": {
    "url": "https://github.com/jagreehal/autotel/issues"
  },
  "homepage": "https://github.com/jagreehal/autotel/tree/main/packages/autotel-edge#readme"
}
