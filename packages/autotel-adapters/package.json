{
  "name": "autotel-adapters",
  "version": "0.3.13",
  "description": "Framework adapters and composable DX helpers for autotel",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "require": "./dist/core.cjs"
    },
    "./hono": {
      "types": "./dist/hono.d.ts",
      "import": "./dist/hono.js",
      "require": "./dist/hono.cjs"
    },
    "./tanstack": {
      "types": "./dist/tanstack.d.ts",
      "import": "./dist/tanstack.js",
      "require": "./dist/tanstack.cjs"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js",
      "require": "./dist/next.cjs"
    },
    "./nitro": {
      "types": "./dist/nitro.d.ts",
      "import": "./dist/nitro.js",
      "require": "./dist/nitro.cjs"
    },
    "./cloudflare": {
      "types": "./dist/cloudflare.d.ts",
      "import": "./dist/cloudflare.js",
      "require": "./dist/cloudflare.cjs"
    },
    "./express": {
      "types": "./dist/express.d.ts",
      "import": "./dist/express.js",
      "require": "./dist/express.cjs"
    },
    "./fastify": {
      "types": "./dist/fastify.d.ts",
      "import": "./dist/fastify.js",
      "require": "./dist/fastify.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "skills"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "autotel": "workspace:*"
  },
  "peerDependencies": {
    "hono": ">=4.12.23",
    "@tanstack/react-start": "^1.168.25",
    "@tanstack/solid-start": "^1.168.25",
    "next": ">=16.2.7",
    "h3": "^2.0.0",
    "nitropack": "^2.13.4"
  },
  "peerDependenciesMeta": {
    "hono": {
      "optional": true
    },
    "@tanstack/react-start": {
      "optional": true
    },
    "@tanstack/solid-start": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "h3": {
      "optional": true
    },
    "nitropack": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "hono": "^4.12.23",
    "rimraf": "^6.1.3",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jagreehal/autotel",
    "directory": "packages/autotel-adapters"
  }
}
