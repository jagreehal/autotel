{
  "name": "autotel-adapters",
  "version": "0.1.1",
  "description": "Framework adapters and composable DX helpers for autotel",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "require": "./dist/core.cjs"
    },
    "./hono": {
      "types": "./dist/hono.d.ts",
      "import": "./dist/hono.js",
      "require": "./dist/hono.cjs"
    },
    "./tanstack": {
      "types": "./dist/tanstack.d.ts",
      "import": "./dist/tanstack.js",
      "require": "./dist/tanstack.cjs"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js",
      "require": "./dist/next.cjs"
    },
    "./nitro": {
      "types": "./dist/nitro.d.ts",
      "import": "./dist/nitro.js",
      "require": "./dist/nitro.cjs"
    },
    "./cloudflare": {
      "types": "./dist/cloudflare.d.ts",
      "import": "./dist/cloudflare.js",
      "require": "./dist/cloudflare.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "autotel": "workspace:*"
  },
  "peerDependencies": {
    "hono": ">=4.12.3",
    "@tanstack/react-start": "^1.166.1",
    "@tanstack/solid-start": "^1.166.1",
    "next": ">=16.1.6",
    "h3": "^1.15.5",
    "nitropack": "^2.13.1"
  },
  "peerDependenciesMeta": {
    "hono": {
      "optional": true
    },
    "@tanstack/react-start": {
      "optional": true
    },
    "@tanstack/solid-start": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "h3": {
      "optional": true
    },
    "nitropack": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "hono": "^4.12.3",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jagreehal/autotel",
    "directory": "packages/autotel-adapters"
  }
}
