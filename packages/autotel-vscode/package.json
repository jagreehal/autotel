{
  "name": "autotel-vscode",
  "version": "0.1.2",
  "private": true,
  "displayName": "Autotel",
  "description": "OpenTelemetry observability inside VSCode — receives OTLP, navigates traces, jumps to source.",
  "publisher": "jagreehal",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jagreehal/autotel",
    "directory": "packages/autotel-vscode"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Debuggers",
    "Visualization",
    "Other"
  ],
  "icon": "resources/icon.png",
  "main": "./dist/extension.js",
  "scripts": {
    "build": "tsup && vite build --config vite.webview.config.ts",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "vsce package --no-dependencies",
    "vsce:publish": "vsce publish --no-dependencies"
  },
  "activationEvents": [
    "onView:autotel.services",
    "onCommand:autotel.start",
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "autotel",
          "title": "Autotel",
          "icon": "resources/activity-bar.svg"
        }
      ]
    },
    "views": {
      "autotel": [
        {
          "id": "autotel.services",
          "name": "Services",
          "icon": "$(server)"
        },
        {
          "id": "autotel.traces",
          "name": "Traces",
          "icon": "$(list-tree)"
        },
        {
          "id": "autotel.logs",
          "name": "Logs",
          "icon": "$(output)"
        },
        {
          "id": "autotel.errors",
          "name": "Errors",
          "icon": "$(error)"
        }
      ]
    },
    "commands": [
      {
        "command": "autotel.start",
        "title": "Autotel: Start Receiver"
      },
      {
        "command": "autotel.stop",
        "title": "Autotel: Stop Receiver"
      },
      {
        "command": "autotel.setPort",
        "title": "Autotel: Set Receiver Port"
      },
      {
        "command": "autotel.clear",
        "title": "Autotel: Clear Buffered Data"
      },
      {
        "command": "autotel.revealSource",
        "title": "Autotel: Reveal Span Source"
      },
      {
        "command": "autotel.copySpanId",
        "title": "Autotel: Copy Span ID"
      },
      {
        "command": "autotel.openSpanDetail",
        "title": "Autotel: Open Span Detail"
      },
      {
        "command": "autotel.openDevtools",
        "title": "Autotel: Open Devtools UI"
      }
    ],
    "configuration": {
      "title": "Autotel",
      "properties": {
        "autotel.receiver.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Boot the OTLP receiver on extension activation."
        },
        "autotel.receiver.port": {
          "type": "number",
          "default": 4318,
          "description": "Port the OTLP HTTP receiver binds to."
        },
        "autotel.receiver.host": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "Host to bind. Use 0.0.0.0 to expose beyond loopback (NOT recommended)."
        },
        "autotel.buffer.maxSpans": {
          "type": "number",
          "default": 10000
        },
        "autotel.buffer.maxLogs": {
          "type": "number",
          "default": 10000
        },
        "autotel.buffer.maxAgeMs": {
          "type": "number",
          "default": 1800000
        },
        "autotel.devtools.url": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "URL of a running autotel-devtools UI to embed via Autotel: Open Devtools UI. When null, falls back to http://<receiver.host>:<receiver.port>."
        }
      }
    }
  },
  "dependencies": {
    "@preact/signals-core": "^1.14.2",
    "autotel-devtools": "workspace:*"
  },
  "peerDependencies": {
    "autotel": "workspace:*"
  },
  "peerDependenciesMeta": {
    "autotel": {
      "optional": true
    }
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.5",
    "@types/node": "^25.7.0",
    "@types/vscode": "^1.118.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "ovsx": "^0.10.12",
    "preact": "^10.29.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.6"
  },
  "files": [
    "dist",
    "resources",
    "LICENSE",
    "README.md"
  ]
}
