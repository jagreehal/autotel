{
  "name": "autotel-vscode",
  "version": "1.1.0",
  "private": true,
  "displayName": "Autotel",
  "description": "OpenTelemetry observability inside VSCode — receives OTLP, navigates traces, jumps to source.",
  "publisher": "jagreehal",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jagreehal/autotel",
    "directory": "packages/autotel-vscode"
  },
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Debuggers",
    "Visualization",
    "Other"
  ],
  "icon": "resources/icon.png",
  "main": "./dist/extension.js",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "vsce package --no-dependencies",
    "vsce:publish": "vsce publish --no-dependencies",
    "ovsx:publish": "ovsx publish --no-dependencies"
  },
  "activationEvents": [
    "onView:autotel.services",
    "onCommand:autotel.start",
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "autotel",
          "title": "Autotel",
          "icon": "resources/activity-bar.svg"
        }
      ]
    },
    "views": {
      "autotel": [
        {
          "id": "autotel.services",
          "name": "Services",
          "icon": "$(server)"
        },
        {
          "id": "autotel.traces",
          "name": "Traces",
          "icon": "$(list-tree)"
        },
        {
          "id": "autotel.logs",
          "name": "Logs",
          "icon": "$(output)"
        },
        {
          "id": "autotel.errors",
          "name": "Errors",
          "icon": "$(error)"
        }
      ]
    },
    "commands": [
      {
        "command": "autotel.start",
        "title": "Autotel: Start Receiver"
      },
      {
        "command": "autotel.stop",
        "title": "Autotel: Stop Receiver"
      },
      {
        "command": "autotel.setPort",
        "title": "Autotel: Set Receiver Port"
      },
      {
        "command": "autotel.clear",
        "title": "Autotel: Clear Buffered Data"
      },
      {
        "command": "autotel.revealSource",
        "title": "Autotel: Reveal Span Source"
      },
      {
        "command": "autotel.copySpanId",
        "title": "Autotel: Copy Span ID"
      },
      {
        "command": "autotel.openSpanDetail",
        "title": "Autotel: Open Span Detail"
      },
      {
        "command": "autotel.openDevtools",
        "title": "Autotel: Open Devtools UI"
      },
      {
        "command": "autotel.queryBackend",
        "title": "Autotel: Query Remote Backend"
      },
      {
        "command": "autotel.setBackendCredential",
        "title": "Autotel: Set Remote Backend Credential"
      },
      {
        "command": "autotel.clearBackendCredential",
        "title": "Autotel: Clear Remote Backend Credential"
      },
      {
        "command": "autotel.openMetrics",
        "title": "Autotel: Open Metrics Panel"
      },
      {
        "command": "autotel.openServiceMap",
        "title": "Autotel: Open Service Map"
      }
    ],
    "configuration": {
      "title": "Autotel",
      "properties": {
        "autotel.receiver.autoStart": {
          "type": "string",
          "enum": [
            "off",
            "onAutotelProject",
            "always"
          ],
          "enumDescriptions": [
            "Never start automatically. Run \"Autotel: Start Receiver\" or click the status bar item to start.",
            "Start automatically only when the workspace depends on autotel; otherwise stay dormant until started manually.",
            "Start automatically in every workspace on activation (the pre-1.1 behaviour)."
          ],
          "default": "onAutotelProject",
          "description": "When the OTLP receiver should start. By default it only auto-starts in projects that depend on autotel; elsewhere start it manually."
        },
        "autotel.receiver.port": {
          "type": "number",
          "default": 4318,
          "description": "Port the OTLP HTTP receiver binds to."
        },
        "autotel.receiver.host": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "Host to bind. Use 0.0.0.0 to expose beyond loopback (NOT recommended)."
        },
        "autotel.buffer.maxSpans": {
          "type": "number",
          "default": 10000
        },
        "autotel.buffer.maxLogs": {
          "type": "number",
          "default": 10000
        },
        "autotel.buffer.maxAgeMs": {
          "type": "number",
          "default": 1800000
        },
        "autotel.devtools.url": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "URL of a running autotel-devtools UI to embed via Autotel: Open Devtools UI. When null, falls back to http://<receiver.host>:<receiver.port>."
        },
        "autotel.backend.type": {
          "type": "string",
          "enum": [
            "none",
            "jaeger",
            "tempo",
            "honeycomb",
            "datadog",
            "logfire",
            "signoz"
          ],
          "default": "none",
          "description": "Read traces from a remote OTel-compatible backend in addition to the local receiver. Credentials live in vscode SecretStorage, never in settings."
        },
        "autotel.backend.dataset": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "Dataset/scope identifier required by some backends (e.g. Honeycomb dataset name)."
        },
        "autotel.backend.url": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "Base URL of the remote backend (e.g. http://localhost:16686 for Jaeger)."
        },
        "autotel.codeLens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show telemetry stats (count, p50, p95, error rate) above instrumented functions."
        }
      }
    }
  },
  "dependencies": {
    "autotel-devtools": "workspace:*"
  },
  "peerDependencies": {
    "autotel": "workspace:*"
  },
  "peerDependenciesMeta": {
    "autotel": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/vscode": "^1.125.0",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "ovsx": "^1.0.2",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "files": [
    "dist",
    "resources",
    "LICENSE",
    "README.md"
  ]
}
