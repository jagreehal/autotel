{
  "name": "autotel-vitest",
  "version": "0.4.38",
  "description": "Vitest fixture for OpenTelemetry: one span per test so all instrumented code is filterable by test run",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./reporter": {
      "types": "./dist/reporter.d.ts",
      "import": "./dist/reporter.js",
      "require": "./dist/reporter.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "skills"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:compat": "vitest run --config integration/vitest.config.ts",
    "test:watch": "vitest",
    "lint": "eslint src",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "autotel": "workspace:*"
  },
  "peerDependencies": {
    "vitest": ">=4.1.10"
  },
  "peerDependenciesMeta": {
    "vitest": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jagreehal/autotel",
    "directory": "packages/autotel-vitest"
  }
}
