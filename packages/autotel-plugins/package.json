{
  "name": "autotel-plugins",
  "version": "0.19.29",
  "description": "OpenTelemetry instrumentation for libraries without official support (BigQuery)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./bigquery": {
      "types": "./dist/bigquery.d.ts",
      "import": "./dist/bigquery.js",
      "require": "./dist/bigquery.cjs"
    },
    "./kafka": {
      "types": "./dist/kafka.d.ts",
      "import": "./dist/kafka.js",
      "require": "./dist/kafka.cjs"
    },
    "./rabbitmq": {
      "types": "./dist/rabbitmq.d.ts",
      "import": "./dist/rabbitmq.js",
      "require": "./dist/rabbitmq.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "ci": "npm run build && npm run check-format && npm run check-exports && npm run lint && npm run test",
    "dev": "tsdown --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check src/**/*.ts",
    "type-check": "tsc --noEmit",
    "test": "vitest run --config vitest.unit.config.ts",
    "test:watch": "vitest --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:watch": "vitest --config vitest.integration.config.ts",
    "test:all": "pnpm test && pnpm test:integration",
    "check-format": "prettier --check ./src",
    "check-exports": "attw --pack . --ignore-rules false-esm no-resolution cjs-resolves-to-esm",
    "clean": "rimraf dist",
    "quality": "pnpm type-check && pnpm test && pnpm lint && pnpm format:check && pnpm build && pnpm check-exports"
  },
  "keywords": [
    "opentelemetry",
    "otel",
    "instrumentation",
    "plugins",
    "bigquery",
    "google-cloud",
    "gcp",
    "kafka",
    "kafkajs",
    "rabbitmq",
    "amqp",
    "amqplib",
    "messaging",
    "event-driven",
    "database",
    "orm",
    "observability",
    "tracing",
    "telemetry"
  ],
  "author": "Jag Reehal <jag@jagreehal.com> (https://jagreehal.com)",
  "license": "MIT",
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/instrumentation": "^0.218.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "autotel": "workspace:*"
  },
  "peerDependencies": {
    "@google-cloud/bigquery": ">=8.3.1",
    "@opentelemetry/instrumentation-amqplib": ">=0.65.0",
    "@opentelemetry/instrumentation-kafkajs": ">=0.27.0"
  },
  "peerDependenciesMeta": {
    "@google-cloud/bigquery": {
      "optional": true
    },
    "@opentelemetry/instrumentation-kafkajs": {
      "optional": true
    },
    "@opentelemetry/instrumentation-amqplib": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@google-cloud/bigquery": "^8.3.1",
    "@opentelemetry/core": "^2.7.1",
    "@types/node": "^25.9.2",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-unicorn": "^64.0.0",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jagreehal/autotel",
    "directory": "packages/autotel-plugins"
  },
  "bugs": {
    "url": "https://github.com/jagreehal/autotel/issues"
  },
  "homepage": "https://github.com/jagreehal/autotel#readme"
}
