{
  "name": "autotel-mongoose",
  "version": "13.0.1",
  "description": "OpenTelemetry instrumentation for Mongoose with db.query.text capture and automatic redaction",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "skills"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "clean": "rimraf dist",
    "format": "prettier --write .",
    "format:check": "prettier --check src/**/*.ts",
    "quality": "pnpm type-check && pnpm test && pnpm lint && pnpm format:check && pnpm build"
  },
  "keywords": [
    "opentelemetry",
    "otel",
    "mongoose",
    "mongodb",
    "observability",
    "instrumentation",
    "tracing",
    "redaction"
  ],
  "author": "Jag Reehal <jag@jagreehal.com> (https://jagreehal.com)",
  "license": "Apache-2.0",
  "peerDependencies": {
    "mongoose": ">=9.7.4",
    "autotel": "*"
  },
  "devDependencies": {
    "@opentelemetry/context-async-hooks": "^2.7.1",
    "@opentelemetry/core": "^2.7.1",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "@types/node": "^26.1.0",
    "autotel": "workspace:*",
    "kareem": "^3.3.0",
    "kareem2": "npm:kareem@^2.6.3",
    "mongodb-memory-server": "^11.2.0",
    "mongoose": "^9.7.4",
    "rimraf": "^6.1.3",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jagreehal/autotel",
    "directory": "packages/autotel-mongoose"
  },
  "bugs": {
    "url": "https://github.com/jagreehal/autotel/issues"
  },
  "homepage": "https://github.com/jagreehal/autotel/tree/main/packages/autotel-mongoose#readme"
}
