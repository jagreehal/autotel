{
  "name": "autotel-hono",
  "version": "0.4.10",
  "description": "OpenTelemetry Hono middleware powered by autotel",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "skills",
    "!skills/_artifacts",
    "bin"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@tanstack/intent": "^0.0.36",
    "autotel": "workspace:*",
    "autotel-adapters": "workspace:*"
  },
  "peerDependencies": {
    "hono": ">=4.12.15"
  },
  "peerDependenciesMeta": {
    "hono": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "hono": "^4.12.12",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jagreehal/autotel",
    "directory": "packages/autotel-hono"
  },
  "bin": {
    "intent": "./bin/intent.js"
  }
}
