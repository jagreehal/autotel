{
  "name": "autotel-hono",
  "version": "0.4.38",
  "description": "OpenTelemetry Hono middleware powered by autotel",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "skills"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "autotel": "workspace:*",
    "autotel-adapters": "workspace:*"
  },
  "peerDependencies": {
    "hono": ">=4.12.28"
  },
  "peerDependenciesMeta": {
    "hono": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "hono": "^4.12.28",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jagreehal/autotel",
    "directory": "packages/autotel-hono"
  }
}
