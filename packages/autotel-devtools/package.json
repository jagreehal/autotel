{
  "name": "autotel-devtools",
  "version": "2.1.0",
  "description": "Standalone OTLP receiver with web UI for local development",
  "type": "module",
  "sideEffects": false,
  "bin": {
    "autotel-devtools": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.cjs"
    },
    "./exporter": {
      "types": "./dist/server/exporter.d.ts",
      "import": "./dist/server/exporter.js",
      "require": "./dist/server/exporter.cjs"
    },
    "./genai": {
      "types": "./dist/genai/index.d.ts",
      "import": "./dist/genai/index.js",
      "require": "./dist/genai/index.cjs"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "skills"
  ],
  "keywords": [
    "opentelemetry",
    "otel",
    "devtools",
    "observability",
    "traces",
    "logs",
    "metrics",
    "otlp",
    "dashboard",
    "widget"
  ],
  "scripts": {
    "build": "tsup && vite build --config vite.widget.config.ts",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run --config vitest.config.ts && vitest run --config vitest.storybook.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@preact/signals": "^2.9.0",
    "clsx": "^2.1.1",
    "lucide-preact": "^1.14.0",
    "markdown-to-jsx": "^9.8.0",
    "preact": "^10.29.1",
    "react-json-view-lite": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.2",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/core": "^2.7.1",
    "@opentelemetry/sdk-logs": "^0.218.0",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@preact/preset-vite": "^2.10.5",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-vitest": "^10.3.6",
    "@storybook/preact-vite": "^10.3.6",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/preact": "^3.2.4",
    "@types/node": "^25.7.0",
    "@types/ws": "^8.18.1",
    "@vitest/browser-playwright": "4.1.6",
    "@vitest/coverage-v8": "4.1.6",
    "eslint-plugin-storybook": "^10.3.6",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "postcss": "^8.5.14",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "storybook": "^10.3.6",
    "tailwindcss": "^4.3.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.6",
    "vitest-mock-extended": "^4.0.0"
  },
  "peerDependencies": {
    "autotel": "workspace:*"
  },
  "peerDependenciesMeta": {
    "autotel": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jagreehal/autotel",
    "directory": "packages/autotel-devtools"
  },
  "license": "MIT"
}
