{
  "name": "autotel-devtools",
  "version": "12.3.0",
  "description": "Standalone OTLP receiver with web UI for local development",
  "type": "module",
  "sideEffects": false,
  "bin": {
    "autotel-devtools": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.cjs"
    },
    "./exporter": {
      "types": "./dist/server/exporter.d.ts",
      "import": "./dist/server/exporter.js",
      "require": "./dist/server/exporter.cjs"
    },
    "./genai": {
      "types": "./dist/genai/index.d.ts",
      "import": "./dist/genai/index.js",
      "require": "./dist/genai/index.cjs"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "skills"
  ],
  "keywords": [
    "opentelemetry",
    "otel",
    "devtools",
    "observability",
    "traces",
    "logs",
    "metrics",
    "otlp",
    "dashboard",
    "widget"
  ],
  "scripts": {
    "build": "tsdown && vite build --config vite.widget.config.ts",
    "dev": "tsdown --watch",
    "type-check": "svelte-check --tsconfig ./tsconfig.json && tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run --config vitest.config.ts --project server && vitest run --config vitest.config.ts --project widget && vitest run --config vitest.storybook.config.ts",
    "test:storybook": "vitest run --config vitest.storybook.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:dist": "node scripts/check-dist-esm.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepublishOnly": "pnpm build && pnpm test:dist"
  },
  "dependencies": {
    "autotel-agents": "workspace:*",
    "clsx": "^2.1.1",
    "@lucide/svelte": "^1.23.0",
    "protobufjs": "^8.7.0",
    "svelte": "^5.56.4",
    "tailwind-merge": "^3.6.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/core": "^2.7.1",
    "@opentelemetry/otlp-transformer": "^0.218.0",
    "@opentelemetry/sdk-logs": "^0.218.0",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/svelte-vite": "^10.4.6",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.4.2",
    "@types/node": "^26.1.0",
    "@types/ws": "^8.18.1",
    "@vitest/browser-playwright": "4.1.10",
    "@vitest/coverage-v8": "4.1.10",
    "eslint-plugin-storybook": "^10.4.6",
    "eslint-plugin-svelte": "^3.20.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "postcss": "^8.5.16",
    "storybook": "^10.4.6",
    "svelte-check": "^4.7.2",
    "tailwindcss": "^4.3.2",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10",
    "vitest-browser-svelte": "^2.2.0",
    "vitest-mock-extended": "^4.0.0"
  },
  "peerDependencies": {
    "autotel": "workspace:*"
  },
  "peerDependenciesMeta": {
    "autotel": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jagreehal/autotel",
    "directory": "packages/autotel-devtools"
  },
  "license": "Apache-2.0"
}
