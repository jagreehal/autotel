{
  "name": "autotel-sentry",
  "version": "0.5.8",
  "description": "Bridge OpenTelemetry (Autotel) traces to Sentry via SpanProcessor and Propagator",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1"
  },
  "peerDependencies": {
    "@sentry/node": ">=10.51.0"
  },
  "peerDependenciesMeta": {
    "@sentry/node": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "keywords": [
    "opentelemetry",
    "otel",
    "sentry",
    "tracing",
    "observability",
    "autotel"
  ],
  "author": "Jag Reehal <jag@jagreehal.com> (https://jagreehal.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jagreehal/autotel",
    "directory": "packages/autotel-sentry"
  }
}