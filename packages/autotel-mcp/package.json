{
  "name": "autotel-mcp",
  "version": "0.1.1",
  "description": "MCP server for AI agents to investigate OpenTelemetry traces, metrics, and logs",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "autotel-mcp": "./bin/autotel-mcp"
  },
  "files": [
    "dist",
    "src",
    "bin",
    "fixtures",
    "skills",
    "!skills/_artifacts",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/server.ts",
    "dev:http": "AUTOTEL_TRANSPORT=http tsx watch src/server.ts",
    "start": "node dist/server.js",
    "start:http": "AUTOTEL_TRANSPORT=http node dist/server.js",
    "lint": "npx eslint src/**/*.ts",
    "lint:fix": "npx eslint src/**/*.ts --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist",
    "format": "prettier --write .",
    "format:check": "prettier --check src/**/*.ts"
  },
  "keywords": [
    "opentelemetry",
    "otel",
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "observability",
    "traces",
    "metrics",
    "logs",
    "otlp",
    "collector",
    "tanstack-intent"
  ],
  "author": "Jag Reehal <jag@jagreehal.com> (https://jagreehal.com)",
  "license": "MIT",
  "dependencies": {
    "ajv": "^8.17.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/otlp-transformer": "^0.214.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@libsql/client": "^0.15.0",
    "yaml": "^2.8.1",
    "zod": "^3.25.48"
  },
  "devDependencies": {
    "@tanstack/intent": "^0.0.29",
    "@types/node": "^25.5.2",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "tsx": "^4.19.4",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jagreehal/autotel",
    "directory": "packages/autotel-mcp"
  },
  "bugs": {
    "url": "https://github.com/jagreehal/autotel/issues"
  },
  "homepage": "https://github.com/jagreehal/autotel/tree/main/packages/autotel-mcp#readme"
}
