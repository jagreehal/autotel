{
  "name": "autotel-terminal",
  "version": "18.0.2",
  "description": "Terminal dashboard for autotel traces using react-ink",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js",
      "require": "./dist/cli.cjs"
    }
  },
  "bin": {
    "autotel-terminal": "./dist/cli.js"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "format:check": "prettier --check src/**/*.ts",
    "lint": "npx eslint src",
    "lint:fix": "npx eslint src --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check-exports": "attw --pack . --ignore-rules false-esm no-resolution cjs-resolves-to-esm",
    "quality": "pnpm type-check && pnpm test && pnpm lint && pnpm format:check && pnpm build && pnpm check-exports"
  },
  "keywords": [
    "autotel",
    "opentelemetry",
    "terminal",
    "dashboard",
    "traces",
    "spans",
    "ink",
    "react",
    "cli",
    "observability"
  ],
  "author": "Jag Reehal<jag@jagreehal.com> (https://jagreehal.com)",
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/openai": "^3.0.52",
    "@ai-sdk/openai-compatible": "^2.0.41",
    "@json-render/core": "^0.16.0",
    "@json-render/ink": "^0.16.0",
    "ai": "^6.0.154",
    "ai-sdk-ollama": "^3.8.2",
    "ink": "^7.0.0",
    "react": "^19.2.5",
    "zod": "4.3.6"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "autotel": "workspace:*"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@opentelemetry/api": "^1.9.1",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "autotel": "workspace:*",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-unicorn": "^64.0.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jagreehal/autotel",
    "directory": "packages/autotel-terminal"
  },
  "bugs": {
    "url": "https://github.com/jagreehal/autotel/issues"
  },
  "homepage": "https://github.com/jagreehal/autotel#readme"
}
